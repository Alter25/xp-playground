{
  "name": "xp",
  "version": "1.0.0",
  "description": "JavaScript playground for Linux desktop",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "node scripts/gen-preview-bundles.mjs && vite build && electron-builder"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "electron": "^35.2.1",
    "electron-builder": "^25.1.8",
    "vite": "^6.3.5",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6",
    "wait-on": "^8.0.3"
  },
  "dependencies": {
    "esbuild": "^0.25.0",
    "monaco-vim": "^0.4.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/browser": "^4.3.0"
  },
  "build": {
    "appId": "com.xp.playground",
    "productName": "XP Playground",
    "asar": true,
    "asarUnpack": [
      "node_modules/@esbuild/**",
      "node_modules/esbuild/bin/**"
    ],
    "files": [
      "dist/**",
      "dist-electron/**",
      "node_modules/esbuild/**",
      "node_modules/@esbuild/**"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Development"
    },
    "directories": {
      "output": "release"
    }
  }
}
